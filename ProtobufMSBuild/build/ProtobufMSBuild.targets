<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<UsingTask TaskName="$(MSBuildThisFileName).ProtobufMSBuildCompile" AssemblyFile="$(MSBuildThisFileDirectory)..\tasks\netstandard2.0\$(MSBuildThisFileName).dll"/>
	<UsingTask TaskName="$(MSBuildThisFileName).ProtobufMSBuildDetermine" AssemblyFile="$(MSBuildThisFileDirectory)..\tasks\netstandard2.0\$(MSBuildThisFileName).dll"/>

	<ItemGroup Label="AutoProtobufInclude" Condition="'$(NoProtobufMSBuildAutoInclude)' != 'true'">
		<Protobuf Include="**/*.proto">
			<ProtobufLanguage>csharp</ProtobufLanguage>
		</Protobuf>
	</ItemGroup>

	<Target Name="ProtobufDetermine">
		<PropertyGroup>
			<ProtobufCompiledDirectory Condition="'$(ProtobufCompiledDirectory)' == ''">$(IntermediateOutputPath)protobufOutput</ProtobufCompiledDirectory>
		</PropertyGroup>

		<ProtobufMSBuildDetermine Protobufs="@(Protobuf)" ProtobufLanguage="%(ProtobufLanguage)" ProjectRoot="$(MSBuildProjectDirectory)" ProtobufCompiledDirectory="$(ProtobufCompiledDirectory)">
			<Output TaskParameter="CompiledProtobufs" ItemName="CompiledProtobufs" />
			<Output Condition="'$(NoProtobufMSBuildAutoIncludeCompile)' != 'true'" TaskParameter="CSCompiledProtobufsAsTaskItem" ItemName="Compile" />
		</ProtobufMSBuildDetermine>
	</Target>

	<Target Name="ProtobufCompile" BeforeTargets="PreBuildEvent" DependsOnTargets="ProtobufDetermine" Inputs="@(Protobuf)" Outputs="@(CompiledProtobufs)">
		<PropertyGroup>
			<ProtobufCompiledDirectory Condition="'$(ProtobufCompiledDirectory)' == ''">$(IntermediateOutputPath)ProtobufOutput</ProtobufCompiledDirectory>
		</PropertyGroup>

		<MakeDir Directories="$(ProtobufCompiledDirectory)" />

		<ProtobufMSBuildCompile Protobufs="@(Protobuf)" ProtobufLanguage="%(ProtobufLanguage)" ProtoCompiler="protoc" ProjectRoot="$(MSBuildProjectDirectory)" ProtobufCompiledDirectory="$(ProtobufCompiledDirectory)" />
	</Target>

	<Target Name="CleanUpProtobufs" BeforeTargets="Clean" DependsOnTargets="ProtobufDetermine">
		<Delete Files="$(CompiledProtobufs)" />
	</Target>
</Project>